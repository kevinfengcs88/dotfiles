{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(uv *)",
      "Bash(curl *)",
      "Bash(pnpm build*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm install*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(git add*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git commit*)",
      "Bash(git log*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git config *)",
      "Bash(gh api *)",
      "Bash(brew list *)",
      "Bash(fc-list)",
      "Bash(system_profiler SPFontsDataType)",
      "Bash(chmod +x ~/.config/sketchybar/plugins/*.sh)",
      "Bash(sketchybar --reload)",
      "Bash(xxd ~/.config/sketchybar/plugins/battery.sh)",
      "Bash(xxd ~/.config/sketchybar/sketchybarrc)",
      "Bash(node /home/kevin/.claude/hooks/gitnexus/gitnexus-hook.cjs*)",
      "Bash(node /Users/kevin/.claude/hooks/gitnexus/gitnexus-hook.cjs*)",
      "Bash(npx gitnexus*)",
      "Bash(gsd*)",
      "Bash(supabase*)",
      "Bash(python3 /home/kevin/projects/slay/scripts/*.py*)",
      "Bash(python3 /Users/kevin/projects/slay/scripts/*.py*)",
      "Bash(rm /home/kevin/projects/slay/.claude/*)",
      "Bash(rm /Users/kevin/projects/slay/.claude/*)",
      "Edit(.claude/*)",
      "Write(.claude/*)",
      "mcp__plugin_supabase_supabase__list_projects",
      "mcp__plugin_supabase_supabase__apply_migration",
      "mcp__plugin_supabase_supabase__execute_sql",
      "mcp__vercel__list_teams",
      "mcp__vercel__list_projects",
      "mcp__vercel__list_deployments",
      "mcp__vercel__get_deployment_build_logs",
      "mcp__vercel__get_deployment",
      "Read(~/.claude/*)",
      "Edit(~/.claude/*)",
      "Write(~/.claude/*)",
      "WebSearch(*)",
      "Skill(ralph-loop*)",
      "Skill(playwright*)",
      "mcp__gitnexus",
      "mcp__plugin_playwright_playwright"
    ],
    "ask": [
      "mcp__plugin_playwright_playwright__browser_run_code_unsafe"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Bash|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/mgrep-enforce.cjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Enriching with GitNexus graph context..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$HOME/.claude/hooks/gsd-worktree-path-guard.js\" ]; then node \"$HOME/.claude/hooks/gsd-worktree-path-guard.js\"; fi",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/gsd-validate-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Checking GitNexus index freshness..."
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/gsd-graphify-update.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/gsd-session-state.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/dotfiles/home/.claude/playtime/playtime.py\" session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/dotfiles/home/.claude/playtime/playtime.py\" session-end",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/dotfiles/home/.claude/playtime/playtime-statusline.sh\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true,
    "ralph-loop@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": false,
    "mgrep@Mixedbread-Grep": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "ecc@ecc": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "Mixedbread-Grep": {
      "source": {
        "source": "github",
        "repo": "mixedbread-ai/mgrep"
      }
    },
    "ecc": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/ECC.git"
      }
    }
  },
  "effortLevel": "high",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "dark",
  "teammateMode": "in-process",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
